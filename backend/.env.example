NODE_ENV=development
PORT=5000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/littlelearners?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# CORS
FRONTEND_URL=http://localhost:3000

# Backend public URL — used to construct video/thumbnail URLs served via /uploads
# On Railway: copy your service's public URL (e.g. https://backend-xyz.up.railway.app)
# Locally: leave as http://localhost:5000
BACKEND_URL=http://localhost:5000

# Email (nodemailer SMTP — Gmail App Password or SendGrid SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=LittleLearners <noreply@littlelearners.in>

# Cloudinary — OPTIONAL upgrade for video CDN delivery
# Without these, rendered videos are served locally via /uploads (works fine for development)
# Sign up free at https://cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ElevenLabs TTS — auto-adds voice narration to generated videos
# Sign up free at https://elevenlabs.io → Profile → API Key
# Free tier: 10,000 characters/month
ELEVENLABS_API_KEY=
# Optional: override the default narrator voice (Rachel — clear, warm)
# Browse voices at elevenlabs.io/voice-library and copy the Voice ID
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Google AI (Veo) — powers AI video generation for lessons
# Get your key at https://aistudio.google.com/apikey (free tier available)
# Veo 2 generates 8-second child-safe educational video clips from text prompts
GOOGLE_AI_API_KEY=
# Optional: override the Veo model (default: veo-2.0-generate-001)
# Use veo-3.1-generate-preview for higher quality (requires Gemini API Pro tier)
VEO_MODEL=veo-2.0-generate-001

# OpenAI — powers the "✨ AI Script" button in the Staff Studio lesson editor
# Sign up at platform.openai.com → API Keys
# Uses gpt-4o-mini — very cheap (~$0.002 per script)
OPENAI_API_KEY=
